<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="500" prefWidth="700" spacing="15.0" style="-fx-padding: 14; -fx-background-color: 00FF00;" styleClass="card" stylesheets="@estilo.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.tienda.PrimaryController">

          <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="title" text="Inventario Oxxo - Sabritas" textFill="WHITE" />

          <HBox spacing="10" style="-fx-background-color: 00FF00;">
        <TextField fx:id="txtId" prefHeight="35.0" prefWidth="60.0" promptText="ID" styleClass="input" />
        <TextField fx:id="txtMarca" prefHeight="35.0" prefWidth="154.0" promptText="Marca" styleClass="input" />
        <TextField fx:id="txtGramos" prefHeight="26.0" prefWidth="110.0" promptText="Gramos" styleClass="input" />
      <TextField fx:id="txtPrecio" layoutX="245.0" layoutY="10.0" prefHeight="26.0" prefWidth="110.0" promptText="Precio" styleClass="input" />
      <TextField fx:id="txtStock" layoutX="366.0" layoutY="10.0" prefHeight="35.0" prefWidth="79.0" promptText="Stock" styleClass="input" />
    </HBox>

          <HBox spacing="10">
        <Button onAction="#onAgregar" styleClass="btn" text="Agregar" textFill="#c100ff" />
        <Button onAction="#onEditar" styleClass="btn" text="Editar por ID" />
        <Button onAction="#onEliminar" styleClass="btn-danger" text="Eliminar por ID" textFill="RED" />
      <Button layoutX="112.0" layoutY="10.0" onAction="#onAbrirVentas" styleClass="btn" text="Ventas" />
    </HBox>

          <TableView fx:id="tabla" prefHeight="302.0" prefWidth="634.0">
        <columns>
            <TableColumn fx:id="colId" prefWidth="120" text="ID" />
            <TableColumn fx:id="colMarca" prefWidth="300" text="Marca" />
            <TableColumn fx:id="colGramos" prefWidth="120" text="Gramos" />
         <TableColumn fx:id="colPrecio" prefWidth="120" text="Precio" />
         <TableColumn fx:id="colStock" prefWidth="120" text="Stock" />
        </columns>
      <columnResizePolicy>
         <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
      </columnResizePolicy>
    </TableView>

          <Label fx:id="lblEstado" style="-fx-text-fill: #333;" text="Estado: listo" />
    
        
    <Button onAction="#onCerrarSesion" styleClass="btn" text="Cerrar sesión" />
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

      </VBox>
