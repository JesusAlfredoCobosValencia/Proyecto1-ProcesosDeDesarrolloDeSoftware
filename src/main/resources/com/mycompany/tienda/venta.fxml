<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.tienda.VentaController">
   <center>
      <HBox spacing="15.0">
         <children>
            <VBox alignment="CENTER" prefHeight="320.0" prefWidth="320.0" spacing="10.0">
               <children>
                  <Label alignment="CENTER" text="Inventario disponible">
                     <font>
                        <Font name="Swis721 BlkCn BT Black" size="13.0" />
                     </font>
                  </Label>
                  <TableView fx:id="tablaProductos" prefHeight="400.0" prefWidth="420.0">
                    <columns>
                      <TableColumn fx:id="colIdProducto" prefWidth="40.0" text="ID" />
                      <TableColumn fx:id="colMarcaProducto" minWidth="100.0" prefWidth="100.0" text="Marca" />
                        <TableColumn fx:id="colGramosProducto" minWidth="50.0" prefWidth="50.0" text="Gramos" />
                        <TableColumn fx:id="colPrecioProducto" minWidth="70.0" prefWidth="75.0" text="Precio" />
                        <TableColumn fx:id="colStockProducto" minWidth="60.0" prefWidth="60.0" text="Stock" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="180.0" prefWidth="180.0" spacing="12.0">
               <children>
                  <Label text="Cantidad" />
                  <TextField fx:id="txtCantidad" promptText="Cantidad" />
                  <Button mnemonicParsing="false" onAction="#onAgregarCarrito" text="Agregar al carrito" />
                  <Button mnemonicParsing="false" onAction="#onEliminarDelCarrito" text="Eliminar del carrito" />
                  <Button mnemonicParsing="false" onAction="#onLimpiarCarrito" text="Limpiar carrito" />
                  <Button mnemonicParsing="false" onAction="#onFinalizarVenta" text="Finalizar venta" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="320.0" prefWidth="320.0" spacing="10.0">
               <children>
                  <Label text="Carrito de compra">
                     <font>
                        <Font name="Swis721 Blk BT Black" size="13.0" />
                     </font>
                  </Label>
                  <TableView fx:id="tablaCarrito" prefHeight="400.0" prefWidth="420.0">
                    <columns>
                      <TableColumn fx:id="colMarcaCarrito" minWidth="100.0" prefWidth="75.0" text="Producto" />
                      <TableColumn fx:id="colCantidadCarrito" minWidth="60.0" prefWidth="75.0" text="Cantidad" />
                        <TableColumn fx:id="colPrecioUnitarioCarrito" minWidth="60.0" prefWidth="75.0" text="Precio Unitario" />
                        <TableColumn fx:id="colSubtotalCarrito" minWidth="60.0" prefWidth="70.0" text="Subtotal" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
         <BorderPane.margin>
            <Insets />
         </BorderPane.margin>
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
      </HBox>
   </center>
   <top>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label alignment="CENTER" contentDisplay="CENTER" prefHeight="102.0" prefWidth="284.0" text="Modulo de ventas">
               <font>
                  <Font name="Swis721 Cn BT Bold" size="21.0" />
               </font>
            </Label>
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#onVolver" text="Volver">
               <font>
                  <Font name="Swis721 Blk BT Black" size="12.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </top>
   <bottom>
      <HBox prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label fx:id="lblTotal" text="Total :" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Label fx:id="lblEstado" text="Estado:" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
